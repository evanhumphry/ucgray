---
layout: layouts/base.njk
title: Contact Us
description: Get in touch with G.R.A.Y. We'd love to hear from you.
---

<section class="page-header">
  <h1>Contact Us</h1>
  <p>Have questions or want to get involved? We'd love to hear from you.</p>
</section>

<section class="section">
  <div class="form-container">
    <form action="https://formspree.io/f/your-form-id" method="POST">
      <div class="form-group">
        <label for="name">Full Name</label>
        <input type="text" id="name" name="name" required>
      </div>
      <div class="form-group">
        <label for="email">Email Address</label>
        <input type="email" id="email" name="email" required>
      </div>
      <div class="form-group">
        <label for="subject">Subject</label>
        <select id="subject" name="subject">
          <option value="general">General Inquiry</option>
          <option value="volunteer">Volunteering</option>
          <option value="donate">Donations</option>
          <option value="hunt">Hunt of a Lifetime</option>
          <option value="partnership">Partnership</option>
        </select>
      </div>
      <div class="form-group">
        <label for="contact-pref">Best way to reach you?</label>
        <select id="contact-pref" name="contact-pref">
          <option value="email">By Email</option>
          <option value="phone">By Phone</option>
        </select>
      </div>
      <div class="form-group">
        <label for="message">Message</label>
        <textarea id="message" name="message" required></textarea>
      </div>
      <button type="submit" class="btn btn-accent">Send Message</button>
    </form>
    <p style="margin-top: 1rem; font-size: 0.9rem; color: var(--gray);"><em>Note: You'll need to set up a <a href="https://formspree.io" target="_blank">Formspree</a> account and replace "your-form-id" in the form action to enable submissions.</em></p>
  </div>
</section>

<section class="section section-alt">
  <div class="container">
    <div class="section-header">
      <h2>Officers</h2>
      <p>Reach out directly to any of our officers.</p>
    </div>
    <div class="card-grid">
      <div class="card" style="text-align: center;">
        <div class="card-icon">&#128100;</div>
        <h3>Pete Caldwell</h3>
        <p>President</p>
        <p><a href="mailto:pete@ucgray.com">pete@ucgray.com</a></p>
      </div>
      <div class="card" style="text-align: center;">
        <div class="card-icon">&#128100;</div>
        <h3>Joel Hasse</h3>
        <p>Treasurer</p>
        <p><a href="mailto:Joel@ucgray.com">Joel@ucgray.com</a></p>
      </div>
      <div class="card" style="text-align: center;">
        <div class="card-icon">&#128100;</div>
        <h3>Darcy Blackman</h3>
        <p>Secretary</p>
        <p><a href="mailto:dblackmanrx@gmail.com">dblackmanrx@gmail.com</a></p>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="card-grid">
      <div class="card" style="text-align: center;">
        <div class="card-icon">&#128231;</div>
        <h3>Email</h3>
        <p><a href="mailto:{{ site.email }}">{{ site.email }}</a></p>
      </div>
      <div class="card" style="text-align: center;">
        <div class="card-icon">&#128205;</div>
        <h3>Mailing Address</h3>
        <p>{{ site.address }}</p>
      </div>
    </div>
  </div>
</section>
